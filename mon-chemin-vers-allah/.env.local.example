# Optionnel — l'application fonctionne sans ces variables (stockage local du navigateur).
# Pour activer la synchronisation cloud, copiez ce fichier en .env.local et remplissez-le
# avec les identifiants de votre projet Supabase (Project Settings > API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
